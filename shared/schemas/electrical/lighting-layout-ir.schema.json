{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shared/schemas/electrical/lighting-layout-ir.schema.json",
  "title": "Lighting Layout IR",
  "description": "Canonical IR schema produced by the lighting-layout skill. Consumed by the DraftsMan runtime renderer (DXF / SVG / PDF). Source-of-truth \u2014 per-skill schemas $ref this file.",
  "type": "object",
  "required": [
    "drawing_type",
    "version",
    "room",
    "calculation_summary",
    "rationale",
    "invariants"
  ],
  "properties": {
    "drawing_type": {
      "const": "lighting_layout"
    },
    "version": {
      "type": "string"
    },
    "room": {
      "type": "object",
      "required": [
        "length_mm",
        "width_mm",
        "area_m2",
        "ceiling_height_mm",
        "room_type"
      ],
      "properties": {
        "length_mm": {
          "type": "integer",
          "minimum": 500
        },
        "width_mm": {
          "type": "integer",
          "minimum": 500
        },
        "area_m2": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ceiling_height_mm": {
          "type": "integer",
          "minimum": 2000
        },
        "working_plane_mm": {
          "type": "integer",
          "minimum": 0
        },
        "hm_mm": {
          "type": "integer",
          "minimum": 0
        },
        "room_index": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "room_type": {
          "enum": [
            "open_plan_office",
            "private_office",
            "meeting_room",
            "corridor",
            "warehouse",
            "warehouse_aisle",
            "classroom",
            "consulting_room",
            "ward",
            "kitchen_commercial",
            "bathroom",
            "reception_lobby",
            "escape_route",
            "plantroom",
            "external"
          ],
          "description": "15-value enum per BS EN 12464-1:2021 Table 5.3 task categories. Matches inputs.json items[room_type].options + 4 added (warehouse_aisle, escape_route, plantroom, external)."
        },
        "environment_type": {
          "type": "string"
        },
        "ip_required": {
          "type": "string"
        },
        "has_windows": {
          "type": "boolean"
        }
      }
    },
    "luminaire_type": {
      "type": "object",
      "required": [
        "symbol",
        "lumens",
        "lumen_type",
        "wattage_w"
      ],
      "properties": {
        "symbol": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "lumens": {
          "type": "integer",
          "minimum": 100
        },
        "lumen_type": {
          "enum": [
            "initial",
            "design",
            "unknown"
          ]
        },
        "llmf_applied": {
          "type": "boolean"
        },
        "initial_lumens": {
          "type": "integer"
        },
        "wattage_w": {
          "type": "integer",
          "minimum": 1
        },
        "cct_k": {
          "type": "integer"
        },
        "cri_ra": {
          "type": "integer"
        },
        "ip_rating": {
          "type": "string"
        },
        "lamp_efficacy_lm_per_w": {
          "type": "number"
        }
      }
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "zone_id",
          "zone_type"
        ],
        "properties": {
          "zone_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "zone_type": {
            "enum": [
              "perimeter",
              "interior",
              "task",
              "emergency"
            ],
            "description": "Part L 2021 / BS EN 15193-1 zone classification. perimeter = within 6m of glazed wall (daylight-linked); interior = >6m from glazing (occupancy-only); task = high-illuminance task area; emergency = escape route / anti-panic / high-risk (BS 5266-1)."
          },
          "control": {
            "enum": [
              "daylight_linked",
              "occupancy",
              "manual",
              "dali_master",
              "emergency_self_test"
            ],
            "description": "Primary control protocol for this zone."
          },
          "circuit_id": {
            "type": "string",
            "description": "Backward-compat: single circuit feeding the zone. Use circuit_ids[] for multi-circuit zones (D3.A.3+)."
          },
          "circuit_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "FK to circuits[].circuit_id. A zone may contain multiple circuits (e.g. zone Z2 interior has 3 row circuits in a 12-luminaire grid)."
          },
          "luminaire_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "FK to luminaires[].id. The full set of luminaires in this zone."
          },
          "luminaire_count": {
            "type": "integer",
            "minimum": 0
          },
          "total_load_w": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "luminaires": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "id",
          "x_mm",
          "y_mm",
          "circuit_id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "x_mm": {
            "type": "integer",
            "minimum": 0
          },
          "y_mm": {
            "type": "integer",
            "minimum": 0
          },
          "zone_id": {
            "type": "string"
          },
          "circuit_id": {
            "type": "string"
          }
        }
      }
    },
    "switches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "x_mm",
          "y_mm",
          "controls_circuit"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "x_mm": {
            "type": "integer",
            "minimum": 0
          },
          "y_mm": {
            "type": "integer",
            "minimum": 0
          },
          "height_aff_mm": {
            "type": "integer"
          },
          "controls_circuit": {
            "type": "string"
          },
          "door_swing": {
            "type": "string"
          },
          "switch_side": {
            "type": "string"
          }
        }
      }
    },
    "circuits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "circuit_id",
          "luminaire_ids",
          "total_load_w",
          "mcb_rating_a"
        ],
        "properties": {
          "circuit_id": {
            "type": "string"
          },
          "db_designation": {
            "type": "string"
          },
          "zone_id": {
            "type": "string"
          },
          "luminaire_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "total_load_w": {
            "type": "number",
            "minimum": 0,
            "description": "Sum of luminaire wattages on this circuit. Capped by allOf conditional per mcb_rating_a (80% continuous-load factor per BS 7671 \u00a7433.1.1 + IET OSG App A): 6A\u21921104W, 10A\u21921840W, 16A\u21922944W, 20A\u21923680W, 32A\u21925888W."
          },
          "mcb_rating_a": {
            "type": "integer",
            "enum": [
              6,
              10,
              16,
              20,
              32
            ]
          },
          "mcb_curve": {
            "enum": [
              "B",
              "C",
              "D"
            ]
          },
          "spare_ways_provided": {
            "type": "integer",
            "minimum": 0
          },
          "row_index": {
            "type": "integer",
            "minimum": 0,
            "description": "Row index this circuit feeds (0 = first row from north wall). Used by INV-4 to verify no Z-pattern daisy-chain \u2014 all luminaires on a circuit must share row_index OR be on adjacent rows (|delta| \u2264 1)."
          },
          "homerun_endpoint": {
            "type": "object",
            "required": [
              "x_mm",
              "y_mm",
              "wall"
            ],
            "additionalProperties": false,
            "description": "Wall endpoint where this circuit's homerun cable exits the room toward the DB. Renderer draws a homerun arrow from this point. INV-4 verifies (a) the point sits on the named wall and (b) the wall is one of the four room walls.",
            "properties": {
              "x_mm": {
                "type": "integer",
                "minimum": 0
              },
              "y_mm": {
                "type": "integer",
                "minimum": 0
              },
              "wall": {
                "enum": [
                  "N",
                  "S",
                  "E",
                  "W"
                ],
                "description": "Which wall the endpoint sits on. Required; not derived. Renderer + INV-4 read this field directly."
              }
            }
          }
        },
        "allOf": [
          {
            "description": "BS 7671 \u00a7433.1.1 + IET OSG App A: continuous load \u2264 80% \u00d7 ocpd_rating \u00d7 230V on each circuit",
            "if": {
              "properties": {
                "mcb_rating_a": {
                  "const": 6
                }
              },
              "required": [
                "mcb_rating_a"
              ]
            },
            "then": {
              "properties": {
                "total_load_w": {
                  "maximum": 1104
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "mcb_rating_a": {
                  "const": 10
                }
              },
              "required": [
                "mcb_rating_a"
              ]
            },
            "then": {
              "properties": {
                "total_load_w": {
                  "maximum": 1840
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "mcb_rating_a": {
                  "const": 16
                }
              },
              "required": [
                "mcb_rating_a"
              ]
            },
            "then": {
              "properties": {
                "total_load_w": {
                  "maximum": 2944
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "mcb_rating_a": {
                  "const": 20
                }
              },
              "required": [
                "mcb_rating_a"
              ]
            },
            "then": {
              "properties": {
                "total_load_w": {
                  "maximum": 3680
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "mcb_rating_a": {
                  "const": 32
                }
              },
              "required": [
                "mcb_rating_a"
              ]
            },
            "then": {
              "properties": {
                "total_load_w": {
                  "maximum": 5888
                }
              }
            }
          }
        ]
      }
    },
    "controls": {
      "type": "object",
      "properties": {
        "dimming_protocol": {
          "type": [
            "string",
            "null"
          ]
        },
        "occupancy_sensing": {
          "type": "boolean"
        },
        "daylight_linking": {
          "type": "boolean"
        },
        "part_l_assessed": {
          "type": "boolean"
        },
        "part_l_compliant": {
          "type": "boolean"
        },
        "part_l_efficacy_target_lm_per_w": {
          "type": "number"
        },
        "lamp_efficacy_lm_per_w": {
          "type": "number"
        },
        "perimeter_zones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "wall": {
                "enum": [
                  "N",
                  "S",
                  "E",
                  "W"
                ]
              },
              "depth_mm": {
                "type": "integer"
              }
            }
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "calculation_summary": {
      "type": "object",
      "required": [
        "target_illuminance_lux",
        "compliant",
        "non_compliance_flags",
        "assumptions"
      ],
      "properties": {
        "target_illuminance_lux": {
          "type": "integer"
        },
        "achieved_illuminance_lux": {
          "type": "number"
        },
        "utilisation_factor": {
          "type": "number"
        },
        "maintenance_factor": {
          "type": "number"
        },
        "lamp_efficacy_lm_per_w": {
          "type": "number"
        },
        "part_l_efficacy_target_lm_per_w": {
          "type": "number"
        },
        "ugr_status": {
          "type": "string"
        },
        "compliant": {
          "type": "boolean"
        },
        "discovery_status": {
          "enum": [
            "complete",
            "incomplete"
          ]
        },
        "missing_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_compliance_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "message"
            ],
            "properties": {
              "message": {
                "type": "string"
              },
              "reference": {
                "type": "string"
              },
              "severity": {
                "enum": [
                  "critical",
                  "warning",
                  "info"
                ]
              }
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "drawing_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Chat-facing high-signal flags (e.g. 'NON-COMPLIANCE', 'INCOMPLETE-INPUT')"
    },
    "rationale": {
      "$ref": "../core/rationale.schema.json"
    },
    "invariants": {
      "type": "array",
      "description": "Validator INVs that fired during generation, with pass/fail + evidence. Populated by generator per validator.md INV list. Empty array is valid for skills where no INV applies to the given example.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "passes",
          "severity",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^INV-[0-9]{2,3}$"
          },
          "passes": {
            "type": "boolean"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1200
          }
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "full_drawing",
        "calc_only"
      ],
      "default": "full_drawing",
      "description": "Output completeness mode. 'full_drawing' = drawable layout with luminaire placement (luminaires/switches/circuits/drawing_notes populated). 'calc_only' = illuminance calculation only, placement deferred (calc_only_reason explains why). Added Sprint D reviewer follow-up to make abbreviated examples explicit rather than silent (fixed shim ref that previously bypassed schema validation)."
    },
    "calc_only_reason": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500,
      "description": "Explanation for why this example is calc_only rather than full_drawing. Required when mode == calc_only."
    },
    "drafting_furniture": {
      "type": "object",
      "description": "Annotation objects emitted alongside the layout for renderer to draw title block, scale bar, dimensions, and luminaire schedule. Required when mode == full_drawing. Every annotation declares explicit font_family + font_size_pt so ezdxf font fallback can resolve without losing tags.",
      "required": [
        "title_block",
        "scale_bar",
        "dimensions",
        "luminaire_schedule"
      ],
      "additionalProperties": false,
      "properties": {
        "title_block": {
          "type": "object",
          "required": [
            "project_name",
            "drawing_number",
            "revision",
            "date",
            "scale",
            "sheet_size",
            "font_family",
            "font_size_pt"
          ],
          "additionalProperties": false,
          "properties": {
            "project_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "drawing_number": {
              "type": "string",
              "minLength": 1,
              "maxLength": 30
            },
            "revision": {
              "type": "string",
              "minLength": 1,
              "maxLength": 8
            },
            "date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "scale": {
              "type": "string",
              "pattern": "^1:\\d+$"
            },
            "sheet_size": {
              "enum": [
                "A0",
                "A1",
                "A2",
                "A3",
                "A4"
              ]
            },
            "font_family": {
              "type": "string",
              "default": "Arial"
            },
            "font_size_pt": {
              "type": "number",
              "minimum": 6,
              "maximum": 24
            }
          }
        },
        "scale_bar": {
          "type": "object",
          "required": [
            "origin_x_mm",
            "origin_y_mm",
            "total_length_mm",
            "tick_interval_mm",
            "font_family",
            "font_size_pt"
          ],
          "additionalProperties": false,
          "properties": {
            "origin_x_mm": {
              "type": "integer",
              "description": "X-coordinate of scale bar origin. May be negative; annotations conventionally sit in negative-space margins outside the room rectangle (model-space origin at room SW corner)."
            },
            "origin_y_mm": {
              "type": "integer",
              "description": "Y-coordinate of scale bar origin. May be negative; annotations conventionally sit in negative-space margins outside the room rectangle (model-space origin at room SW corner)."
            },
            "total_length_mm": {
              "type": "integer",
              "minimum": 1000
            },
            "tick_interval_mm": {
              "type": "integer",
              "minimum": 100
            },
            "font_family": {
              "type": "string",
              "default": "Arial"
            },
            "font_size_pt": {
              "type": "number",
              "minimum": 6,
              "maximum": 12
            }
          }
        },
        "dimensions": {
          "type": "array",
          "minItems": 2,
          "description": "At minimum room length + width dimension lines.",
          "items": {
            "type": "object",
            "required": [
              "axis",
              "start_x_mm",
              "start_y_mm",
              "end_x_mm",
              "end_y_mm",
              "text",
              "font_family",
              "font_size_pt"
            ],
            "additionalProperties": false,
            "properties": {
              "axis": {
                "enum": [
                  "horizontal",
                  "vertical"
                ]
              },
              "start_x_mm": {
                "type": "integer",
                "description": "X-coordinate of dimension line start. May be negative; annotations conventionally sit in negative-space margins outside the room rectangle (model-space origin at room SW corner)."
              },
              "start_y_mm": {
                "type": "integer",
                "description": "Y-coordinate of dimension line start. May be negative; annotations conventionally sit in negative-space margins outside the room rectangle (model-space origin at room SW corner)."
              },
              "end_x_mm": {
                "type": "integer",
                "description": "X-coordinate of dimension line end. May be negative; annotations conventionally sit in negative-space margins outside the room rectangle (model-space origin at room SW corner)."
              },
              "end_y_mm": {
                "type": "integer",
                "description": "Y-coordinate of dimension line end. May be negative; annotations conventionally sit in negative-space margins outside the room rectangle (model-space origin at room SW corner)."
              },
              "text": {
                "type": "string",
                "minLength": 1,
                "maxLength": 30
              },
              "font_family": {
                "type": "string",
                "default": "Arial"
              },
              "font_size_pt": {
                "type": "number",
                "minimum": 6,
                "maximum": 14
              }
            }
          }
        },
        "luminaire_schedule": {
          "type": "object",
          "required": [
            "columns",
            "rows",
            "font_family",
            "font_size_pt"
          ],
          "additionalProperties": false,
          "properties": {
            "columns": {
              "type": "array",
              "minItems": 5,
              "description": "Schedule columns. Required minimum: ref + manufacturer + lumens + wattage + count.",
              "items": {
                "type": "string"
              }
            },
            "rows": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "font_family": {
              "type": "string",
              "default": "Arial"
            },
            "font_size_pt": {
              "type": "number",
              "minimum": 6,
              "maximum": 12
            }
          }
        }
      }
    },
    "selection_source": {
      "type": "object",
      "description": "Records which photometric data path (input override vs ontology default) was used by the lumen-method calculation. INV-8 enforces presence.",
      "required": [
        "photometric_source",
        "citation"
      ],
      "additionalProperties": false,
      "properties": {
        "photometric_source": {
          "enum": [
            "input_override",
            "ontology_default"
          ],
          "description": "input_override = inputs.photometric_override block was supplied and used. ontology_default = generator fell back to ontology/luminaire-types.json defaults."
        },
        "citation": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500,
          "description": "Either the inputs.photometric_override._source string OR the ontology[type].photometric._citation string. Resolves which document authorises the UF + SHR_max + LLMF values used."
        }
      }
    },
    "consumed_intents": {
      "type": "object",
      "additionalProperties": false,
      "description": "Intent payloads consumed from companion skills per skill.manifest.json consumes_intents[]. Required when mode == full_drawing. Currently carries photometric_grid (Wave 1) and special_locations_zoning (Wave 1); future waves add emergency_coverage (Wave 3) and daylight_model (Wave 4).",
      "properties": {
        "photometric_grid": {
          "type": "object",
          "required": [
            "intent_version",
            "source_path",
            "payload"
          ],
          "additionalProperties": false,
          "properties": {
            "intent_version": {
              "type": "string"
            },
            "source_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to photometric-analysis intent-out.json (typically electrical/photometric-analysis/examples/cascade-<this-example-name>/intent-out.json for shipped examples; project-specific path for real projects)"
            },
            "payload": {
              "$ref": "../../../electrical/photometric-analysis/schemas/photometric-grid-intent.schema.json#/properties/photometric_grid"
            }
          }
        },
        "special_locations_zoning": {
          "type": "object",
          "required": ["intent_version", "source_path", "payload"],
          "additionalProperties": false,
          "properties": {
            "intent_version": {"type": "string"},
            "source_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to special-locations intent-out.json. For shipped examples: electrical/special-locations/examples/cascade-<this-example-name>/intent-out.json. For real projects: project-specific path."
            },
            "payload": {
              "$ref": "../../../electrical/special-locations/schemas/special-locations-zoning-intent.schema.json#/properties/special_locations_zoning"
            }
          }
        }
      }
    },
    "floor_plan_context_consumed": {
      "type": "boolean",
      "default": false,
