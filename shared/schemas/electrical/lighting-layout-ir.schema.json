{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shared/schemas/electrical/lighting-layout-ir.schema.json",
  "title": "Lighting Layout IR",
  "description": "Canonical IR schema produced by the lighting-layout skill. Consumed by the DraftsMan runtime renderer (DXF / SVG / PDF). Source-of-truth — per-skill schemas $ref this file.",
  "type": "object",
  "required": [
    "drawing_type",
    "version",
    "room",
    "luminaire_type",
    "luminaires",
    "switches",
    "circuits",
    "controls",
    "calculation_summary",
    "drawing_notes",
    "rationale",
    "invariants"
  ],
  "properties": {
    "drawing_type": {
      "const": "lighting_layout"
    },
    "version": {
      "type": "string"
    },
    "room": {
      "type": "object",
      "required": [
        "length_mm",
        "width_mm",
        "area_m2",
        "ceiling_height_mm",
        "room_type"
      ],
      "properties": {
        "length_mm": {
          "type": "integer",
          "minimum": 500
        },
        "width_mm": {
          "type": "integer",
          "minimum": 500
        },
        "area_m2": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ceiling_height_mm": {
          "type": "integer",
          "minimum": 2000
        },
        "working_plane_mm": {
          "type": "integer",
          "minimum": 0
        },
        "hm_mm": {
          "type": "integer",
          "minimum": 0
        },
        "room_index": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "room_type": {
          "type": "string"
        },
        "environment_type": {
          "type": "string"
        },
        "ip_required": {
          "type": "string"
        },
        "has_windows": {
          "type": "boolean"
        }
      }
    },
    "luminaire_type": {
      "type": "object",
      "required": [
        "symbol",
        "lumens",
        "lumen_type",
        "wattage_w"
      ],
      "properties": {
        "symbol": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "lumens": {
          "type": "integer",
          "minimum": 100
        },
        "lumen_type": {
          "enum": [
            "initial",
            "design",
            "unknown"
          ]
        },
        "llmf_applied": {
          "type": "boolean"
        },
        "initial_lumens": {
          "type": "integer"
        },
        "wattage_w": {
          "type": "integer",
          "minimum": 1
        },
        "cct_k": {
          "type": "integer"
        },
        "cri_ra": {
          "type": "integer"
        },
        "ip_rating": {
          "type": "string"
        },
        "lamp_efficacy_lm_per_w": {
          "type": "number"
        }
      }
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "zone_id",
          "circuit_id"
        ],
        "properties": {
          "zone_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "circuit_id": {
            "type": "string"
          },
          "luminaire_count": {
            "type": "integer",
            "minimum": 0
          },
          "total_load_w": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "luminaires": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "id",
          "x_mm",
          "y_mm",
          "circuit_id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "x_mm": {
            "type": "integer",
            "minimum": 0
          },
          "y_mm": {
            "type": "integer",
            "minimum": 0
          },
          "zone_id": {
            "type": "string"
          },
          "circuit_id": {
            "type": "string"
          }
        }
      }
    },
    "switches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "x_mm",
          "y_mm",
          "controls_circuit"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "x_mm": {
            "type": "integer",
            "minimum": 0
          },
          "y_mm": {
            "type": "integer",
            "minimum": 0
          },
          "height_aff_mm": {
            "type": "integer"
          },
          "controls_circuit": {
            "type": "string"
          },
          "door_swing": {
            "type": "string"
          },
          "switch_side": {
            "type": "string"
          }
        }
      }
    },
    "circuits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "circuit_id",
          "luminaire_ids",
          "total_load_w",
          "mcb_rating_a"
        ],
        "properties": {
          "circuit_id": {
            "type": "string"
          },
          "db_designation": {
            "type": "string"
          },
          "zone_id": {
            "type": "string"
          },
          "luminaire_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "total_load_w": {
            "type": "number",
            "minimum": 0,
            "maximum": 1840
          },
          "mcb_rating_a": {
            "type": "integer",
            "enum": [
              6,
              10,
              16,
              20,
              32
            ]
          },
          "mcb_curve": {
            "enum": [
              "B",
              "C",
              "D"
            ]
          },
          "spare_ways_provided": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "controls": {
      "type": "object",
      "properties": {
        "dimming_protocol": {
          "type": [
            "string",
            "null"
          ]
        },
        "occupancy_sensing": {
          "type": "boolean"
        },
        "daylight_linking": {
          "type": "boolean"
        },
        "part_l_assessed": {
          "type": "boolean"
        },
        "part_l_compliant": {
          "type": "boolean"
        },
        "part_l_efficacy_target_lm_per_w": {
          "type": "number"
        },
        "lamp_efficacy_lm_per_w": {
          "type": "number"
        },
        "perimeter_zones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "wall": {
                "enum": [
                  "N",
                  "S",
                  "E",
                  "W"
                ]
              },
              "depth_mm": {
                "type": "integer"
              }
            }
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "calculation_summary": {
      "type": "object",
      "required": [
        "target_illuminance_lux",
        "compliant",
        "non_compliance_flags",
        "assumptions"
      ],
      "properties": {
        "target_illuminance_lux": {
          "type": "integer"
        },
        "achieved_illuminance_lux": {
          "type": "number"
        },
        "utilisation_factor": {
          "type": "number"
        },
        "maintenance_factor": {
          "type": "number"
        },
        "lamp_efficacy_lm_per_w": {
          "type": "number"
        },
        "part_l_efficacy_target_lm_per_w": {
          "type": "number"
        },
        "ugr_status": {
          "type": "string"
        },
        "compliant": {
          "type": "boolean"
        },
        "discovery_status": {
          "enum": [
            "complete",
            "incomplete"
          ]
        },
        "missing_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_compliance_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "message"
            ],
            "properties": {
              "message": {
                "type": "string"
              },
              "reference": {
                "type": "string"
              },
              "severity": {
                "enum": [
                  "critical",
                  "warning",
                  "info"
                ]
              }
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "drawing_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Chat-facing high-signal flags (e.g. 'NON-COMPLIANCE', 'INCOMPLETE-INPUT')"
    },
    "rationale": {
      "$ref": "../core/rationale.schema.json"
    },
    "invariants": {
      "type": "array",
      "description": "Validator INVs that fired during generation, with pass/fail + evidence. Populated by generator per validator.md INV list. Empty array is valid for skills where no INV applies to the given example.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "passes",
          "severity",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^INV-[0-9]{2,3}$"
          },
          "passes": {
            "type": "boolean"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 20,
            "maxLength": 800
          }
        }
      }
    }
  }
}
