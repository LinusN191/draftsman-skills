{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "electrical/db-layout/schemas/db-layout-intent.schema.json",
  "title": "DB Layout Intent (Single Board)",
  "description": "Stable subset of the db-layout IR for a single board. Consumed by panel-schedule, riser, cable-containment. Wrapped in shared/schemas/core/intent.schema.json envelope at runtime. Forward-compat: optional fields may be added freely; required-field changes require a major intent_version bump.",
  "type": "object",
  "required": ["db_id", "incoming_supply", "circuits"],
  "additionalProperties": false,
  "properties": {
    "db_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9-]{1,15}$"
    },
    "incoming_supply": {
      "type": "object",
      "required": ["voltage_v", "phase_arrangement", "supply_rating_a"],
      "additionalProperties": false,
      "properties": {
        "voltage_v":         { "type": "integer", "enum": [120, 208, 230, 240, 400, 415, 480] },
        "phase_arrangement": { "enum": ["single_phase", "single_phase_split", "TPN", "TPN_plus_E"] },
        "supply_rating_a":   { "type": "integer", "minimum": 6, "maximum": 6300 },
        "fed_from":          { "type": "string" },
        "supply_class":      { "enum": ["essential", "non_essential", "ups", "ups_plus_essential"] }
      }
    },
    "circuits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "module_id", "breaker_rating_a", "breaker_curve", "breaker_breaking_capacity_ka"],
        "additionalProperties": false,
        "properties": {
          "id":                 { "type": "string" },
          "module_id":          { "type": "string" },
          "breaker_rating_a":   { "type": "integer", "enum": [6, 10, 15, 16, 20, 25, 30, 32, 35, 40, 45, 50, 60, 63, 70, 80, 90, 100, 110, 125, 150, 160, 175, 200, 225, 250, 300, 400, 500, 600, 630, 700, 800, 1000, 1200, 1250, 1600, 2000, 2500, 3000, 4000] },
          "breaker_curve":      { "enum": ["B", "C", "D"] },
          "breaker_breaking_capacity_ka": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Rated short-circuit breaking capacity in kA for this circuit's OCPD. Per BS EN 60898 (MCBs) / IEC 60947-2 (MCCBs/ACBs). Used by downstream fault-level for breaking-capacity verdict per BS 7671 Reg 432.1.2 / NEC 110.9. Added Sprint D1.0."
          },
          "rcd_protected":      { "type": "boolean" },
          "rcd_type":           { "enum": ["AC", "A", "F", "B"] },
          "rcd_sensitivity_ma": { "type": "integer", "enum": [10, 30, 100, 300, 500] },
          "cable_csa_mm2":      { "type": "number" },
          "cable_csa_awg":      { "type": "string" },
          "cable_cores":        { "type": "integer", "minimum": 2, "maximum": 5 },
          "voltage_class":      { "enum": ["LV_power", "ELV_control", "comms_data", "fire_alarm", "emergency_lighting"] },
          "downstream_load_kw": { "type": "number", "minimum": 0 },
          "approximate_route_length_m": { "type": "number", "exclusiveMinimum": 0 },
          "diversity_basis": {
            "type": "object",
            "additionalProperties": true,
            "description": "Optional per-circuit diversity audit trail propagated from the IR. Permissive — downstream consumers may inspect load_type + factor_applied to verify which regulation/standard authorises the diversity factor on each circuit. Added Sprint D2.3."
          }
        }
      }
    },
    "board_kind": {
      "enum": ["main_switchboard", "specialty_board"],
      "description": "Board discriminator matching db-layout IR board.board_kind"
    },
    "main_switch": {
      "type": "object",
      "required": ["type", "rating_a", "breaking_capacity_ka"],
      "additionalProperties": false,
      "properties": {
        "type":       { "enum": ["switch-disconnector", "MCCB", "isolator", "RCCB", "RCBO", "main_switch_fused"] },
        "rating_a":   { "type": "number", "exclusiveMinimum": 0 },
        "curve":      { "enum": ["B", "C", "D"] },
        "breaking_capacity_ka": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Rated short-circuit breaking capacity in kA (Icn per BS EN 60898; Icu per IEC 60947-2). Used by downstream fault-level for breaking-capacity verdict per BS 7671 Reg 432.1.2 / NEC 110.9. Added Sprint D1.0 to enable fault-level hybrid consumer pattern (D1.1)."
        }
      }
    },
    "spare_ways":      { "type": "integer", "minimum": 0 },
    "form_separation": { "enum": ["1", "2a", "2b", "3a", "3b", "4a", "4b"] },
    "icw_ka_1s":       { "type": "number", "minimum": 0 },
    "selectivity_tool_call_pending": {
      "type": "boolean",
      "description": "true if any cascade verification in the source IR was deferred to a future fault-level skill invocation"
    },
    "consumed_intents": {
      "type": "object",
      "description": "Wave 1 cascade inputs mirror. Permissive — downstream consumers may inspect special_locations_zoning.payload.electrical_constraints to verify Part-7 protection topology at the circuit-supply level. Added D.5.",
      "additionalProperties": false,
      "properties": {
        "special_locations_zoning": {
          "type": "object",
          "required": ["intent_version", "source_path", "payload"],
          "additionalProperties": false,
          "properties": {
            "intent_version": {"type": "string"},
            "source_path": {"type": "string"},
            "payload": {"type": "object"}
          }
        }
      }
    }
  }
}
