{
  "$schema": "../../shared/schemas/core/inputs.schema.json",
  "skill": "sld",
  "version": "1.3.0",
  "items": [
    {
      "id": "jurisdiction",
      "label": "Jurisdiction",
      "hint": "GB = BS 7671 / EU = IEC 60364 / INT = generic IEC / KE = KS 1700 + IEC 60364 / US = NEC 2023",
      "answer_type": "enum",
      "options": ["GB", "EU", "INT", "KE", "US"],
      "required": true
    },
    {
      "id": "project_id",
      "label": "Project identifier",
      "answer_type": "text",
      "required": true,
      "validator": "non_empty_text"
    },
    {
      "id": "supply_brief",
      "label": "Supply origin (DNO, system type, voltage, Ze, PFC, main switch rating)",
      "hint": "Provide supplier name, system_type (TN-S/TN-C-S/TT), voltage (e.g., 400V), arrangement (TPN/single_phase/etc), frequency, declared Ze in ohms, declared PFC in kA, main switch rating (A) + breaking capacity (kA).",
      "answer_type": "struct_list",
      "required": true,
      "item_schema": {
        "type": "object",
        "required": ["supplier", "system_type", "voltage_nominal_v", "voltage_arrangement", "frequency_hz", "ze_declared_ohm", "pfc_declared_ka", "main_switch_rating_a", "main_switch_breaking_capacity_ka"],
        "properties": {
          "supplier":                       { "type": "string" },
          "wayleave_or_account_reference":  { "type": "string" },
          "system_type":                    { "type": "string" },
          "voltage_nominal_v":              { "type": "integer" },
          "voltage_arrangement":            { "type": "string" },
          "frequency_hz":                   { "type": "integer" },
          "ze_declared_ohm":                { "type": "number" },
          "pfc_declared_ka":                { "type": "number" },
          "main_switch_rating_a":           { "type": "integer" },
          "main_switch_breaking_capacity_ka": { "type": "number" }
        }
      }
    },
    {
      "id": "distribution_hierarchy_brief",
      "label": "Distribution hierarchy — list of boards with consumed_intent_path",
      "hint": "One entry per board. board_id (e.g., MSB-MAIN, SDB-GF), board_role (main_switchboard / sub_distribution_board / panel / sub_panel / fire_alarm_panel / life_safety_panel / ups_distribution), consumed_intent_path (relative path to that board's db-layout intent-out.json), parent_board_id (null for root), fed_via_circuit_id (which upstream circuit feeds this board).",
      "answer_type": "struct_list",
      "required": true,
      "item_schema": {
        "type": "object",
        "required": ["board_id", "board_role", "consumed_intent_path"],
        "properties": {
          "board_id":             { "type": "string" },
          "board_role":           { "type": "string" },
          "consumed_intent_path": { "type": "string" },
          "parent_board_id":      { "type": ["string", "null"] },
          "fed_via_circuit_id":   { "type": ["string", "null"] },
          "location":             { "type": "string" }
        }
      }
    },
    {
      "id": "spd_assessment_inputs",
      "label": "SPD assessment inputs (location type, lightning risk, life-safety presence)",
      "hint": "Inputs for SPD policy lookup per BS 7671 §443 / IEC 60364-4-44 / NEC 285 / KS 1700 §443.",
      "answer_type": "struct_list",
      "required": false,
      "item_schema": {
        "type": "object",
        "properties": {
          "location_type":        { "type": "string" },
          "lightning_risk":       { "enum": ["low", "moderate", "high"] },
          "life_safety_present":  { "type": "boolean" }
        }
      }
    }
  ]
}
